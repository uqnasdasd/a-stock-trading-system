{
  "version": 2,
  "builds": [
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://a-stock-trading-backend.onrender.com/api/$1"
    },
    {
      "src": "/ws/(.*)",
      "dest": "wss://a-stock-trading-backend.onrender.com/ws/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ]
}
