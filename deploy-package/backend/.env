# A股超短交易实时监测系统配置

# 数据源配置
DATA_SOURCE_PRIMARY=sina
DATA_SOURCE_BACKUP=tencent
POLL_INTERVAL=3

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 数据库配置
DATABASE_URL=sqlite:///./trading_system.db

# 告警推送配置
DINGTALK_WEBHOOK=
WECHAT_WEBHOOK=

# 风控配置
MAX_SINGLE_POSITION=0.10
MAX_TOTAL_POSITION=0.50
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.05
DAILY_MAX_LOSS=0.03
WEEKLY_MAX_LOSS=0.05
MAX_TRADES_PER_DAY=2
MAX_TRADES_PER_WEEK=5

# 交易时段
MARKET_OPEN=09:30
MARKET_CLOSE=15:00
AUCTION_START=09:15
AUCTION_END=09:25
MORNING_END=11:30
AFTERNOON_START=13:00
